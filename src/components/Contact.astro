<section id="contact" class="section-padding bg-light-bg">
  <div class="container-custom">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-black text-primary mb-4">Secure Your Appointment</h2>
      <div class="w-20 h-1.5 bg-secondary mx-auto mb-6"></div>
      <p class="text-lg text-gray-600 font-medium leading-relaxed">
        Fill in the form below or reach out to us directly via WhatsApp.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
      <!-- Contact Details Card -->
      <div class="bg-primary text-white p-8 md:p-10 rounded-2xl shadow-xl flex flex-col justify-between">
        <div>
          <h3 class="text-2xl font-bold text-white mb-6">Get in Touch</h3>
          
          <div class="flex items-start gap-4 mb-6">
            <div class="text-2xl text-secondary flex-shrink-0 mt-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin">
                <path d="M12 10a2 2 0 1 0 0 4 2 2 0 0 0 0-4Z"/>
                <path d="M19 10c0 8-7 12-7 12s-7-4-7-12a7 7 0 0 1 14 0Z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-lg font-semibold text-secondary mb-1">Address</h4>
              <p class="text-gray-200">60 Paya Lebar Road, #06-28<br/>Paya Lebar Square, Singapore 409051</p>
              <p class="text-secondary font-bold text-sm mt-2">UEN: 53479502A</p>
            </div>
          </div>

          <div class="flex items-start gap-4 mb-6">
            <div class="text-2xl text-secondary flex-shrink-0 mt-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <div>
              <h4 class="text-lg font-semibold text-secondary mb-1">Email</h4>
              <p><a href="mailto:enquiry@soi.com.sg" class="text-gray-200 hover:underline">enquiry@soi.com.sg</a></p>
            </div>
          </div>

          <div class="flex items-start gap-4 mb-6">
            <div class="text-2xl text-secondary flex-shrink-0 mt-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-lg font-semibold text-secondary mb-1">Phone</h4>
              <p><a href="tel:+6580812300" class="text-gray-200 hover:underline">+65 8081 2300</a></p>
            </div>
          </div>
        </div>

        <div class="flex gap-4 mt-8">
          <a href="https://wa.me/6580812300?text=Hello%2C%20I%27m%20interested%20to%20find%20out%20more%21" target="_blank" class="flex-1 bg-green-500 text-white py-3 rounded-lg font-bold text-center hover:bg-green-600 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="inline-block h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.438 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 2.042-.535zm11.233-6.182c-.3-.149-1.774-.875-2.048-.976-.276-.1-.476-.149-.676.149-.2.299-.775.976-.95 1.171-.175.194-.35.219-.65.07-.3-.149-1.265-.466-2.41-1.581-.892-.796-1.492-1.779-1.667-2.079-.175-.299-.019-.461.13-.61.135-.133.299-.349.449-.524.15-.175.2-.299.299-.499.1-.2.05-.374-.025-.524-.05-.15-.676-1.626-.925-2.221-.244-.582-.493-.503-.676-.503-.175-.004-.375-.004-.574-.004-.2 0-.525.075-.799.374-.274.299-1.049 1.024-1.049 2.495 0 1.471 1.074 2.893 1.223 3.093.15.2 2.114 3.217 5.122 4.517.715.309 1.273.494 1.708.633.717.228 1.369.196 1.885.119.574-.085 1.774-.724 2.023-1.422.25-.699.25-1.297.175-1.422-.075-.125-.275-.199-.575-.349z"/>
            </svg>
            WhatsApp
          </a>
          <a href="http://t.me/spotoninspectorate" target="_blank" class="flex-1 bg-blue-500 text-white py-3 rounded-lg font-bold text-center hover:bg-blue-600 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="inline-block h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.372 3.237c-.328-.135-.716-.118-1.037.042L2.321 9.531a.78.78 0 0 0-.25 1.082c.249.414.739.58 1.222.404l4.242-1.556c.451-.165.929-.001 1.258.373l5.066 4.981-1.434 4.174a.833.833 0 0 0 .285.908c.28.188.64.212.946.064l14.155-6.521c.328-.135.53-.46.53-.825a.798.798 0 0 0-.328-.667z"/>
            </svg>
            Telegram
          </a>
        </div>
      </div>

      <!-- Contact Form Card -->
      <div class="bg-white p-8 md:p-10 rounded-2xl shadow-xl border border-gray-100">
        <div class="mb-8">
          <h3 class="text-2xl font-bold text-primary mb-3">Send us a message</h3>
          <p class="text-gray-600 leading-relaxed">Have questions about your HDB or Condo? Use the form below to get in touch, and our team will get back to you within 1 working day.</p>
        </div>
        <iframe data-tally-src="https://tally.so/embed/mVJk5l?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1" 
                loading="lazy" 
                width="100%" 
                height="450" 
                frameborder="0" 
                marginheight="0" 
                marginwidth="0" 
                title="Contact Us"></iframe>
        <script>
          // Tally.so embed script
          var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach((function(e){e.src=e.dataset.tallySrc}))};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s);}
        </script>
      </div>
    </div>
  </div>
</section>
