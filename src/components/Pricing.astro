---
---
<section class="section-padding bg-white">
  <div class="container-custom">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-black text-primary mb-4">Transparent Pre-Renovation Pricelists</h2>
      <div class="w-20 h-1.5 bg-secondary mx-auto mb-6"></div>
      <p class="text-lg text-gray-600 font-medium leading-relaxed">
        Clear, upfront pricing for HDB and Executive/Condo defect inspections. No hidden fees.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8">
      <!-- HDB Pricelist -->
      <div>
        <h3 class="text-2xl font-bold text-primary mb-6 text-center">HDB Pre-Renovation Pricelist</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-left bg-white shadow-lg rounded-xl overflow-hidden border border-gray-100">
            <thead class="bg-primary text-white">
              <tr>
                <th class="py-4 px-6 font-bold uppercase tracking-wider text-sm">HDB Size</th>
                <th class="py-4 px-6 font-bold uppercase tracking-wider text-sm text-right">Price (S$)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td class="py-3.5 px-6 border-b border-gray-100">2 room</td><td class="py-3.5 px-6 border-b border-gray-100 text-right font-semibold text-secondary">200</td></tr>
              <tr><td class="py-3.5 px-6 border-b border-gray-100">3 room</td><td class="py-3.5 px-6 border-b border-gray-100 text-right font-semibold text-secondary">300</td></tr>
              <tr><td class="py-3.5 px-6 border-b border-gray-100">4 room</td><td class="py-3.5 px-6 border-b border-gray-100 text-right font-semibold text-secondary">400</td></tr>
              <tr><td class="py-3.5 px-6 border-b border-gray-100">5 room</td><td class="py-3.5 px-6 border-b border-gray-100 text-right font-semibold text-secondary">500</td></tr>
              <tr><td class="py-3.5 px-6 border-b border-gray-100">3-Gen</td><td class="py-3.5 px-6 border-b border-gray-100 text-right font-semibold text-secondary">580</td></tr>
              <tr><td class="py-3.5 px-6 bg-gray-50 rounded-b-xl">For HDB types not shown</td><td class="py-3.5 px-6 bg-gray-50 text-right font-semibold text-primary rounded-b-xl">Contact us for quote</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Exec/Condo Pricelist -->
      <div>
        <h3 class="text-2xl font-bold text-primary mb-6 text-center">Exec/Condo Pre-Renovation Pricelist</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-left bg-white shadow-lg rounded-xl overflow-hidden border border-gray-100">
            <thead class="bg-primary text-white">
              <tr>
                <th class="py-4 px-6 font-bold uppercase tracking-wider text-sm">Floor Area</th>
                <th class="py-4 px-6 font-bold uppercase tracking-wider text-sm text-right">Price (S$)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td class="py-3.5 px-6 border-b border-gray-100">Under 500 sqft</td><td class="py-3.5 px-6 border-b border-gray-100 text-right font-semibold text-secondary">350</td></tr>
              <tr><td class="py-3.5 px-6 border-b border-gray-100">501-700 sqft</td><td class="py-3.5 px-6 border-b border-gray-100 text-right font-semibold text-secondary">550</td></tr>
              <tr><td class="py-3.5 px-6 border-b border-gray-100">701-1000 sqft</td><td class="py-3.5 px-6 border-b border-gray-100 text-right font-semibold text-secondary">650</td></tr>
              <tr><td class="py-3.5 px-6 border-b border-gray-100">1001-1200 sqft</td><td class="py-3.5 px-6 border-b border-gray-100 text-right font-semibold text-secondary">750</td></tr>
              <tr><td class="py-3.5 px-6 border-b border-gray-100">1201-1400 sqft</td><td class="py-3.5 px-6 border-b border-gray-100 text-right font-semibold text-secondary">850</td></tr>
              <tr><td class="py-3.5 px-6 bg-gray-50 rounded-b-xl">1401 sqft and above</td><td class="py-3.5 px-6 bg-gray-50 text-right font-semibold text-primary rounded-b-xl">Contact us for quote</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="text-center mt-12">
      <p class="text-lg text-gray-600 font-medium leading-relaxed">
        Have concerns or need specialised requirements? 
        <a href="#contact" class="text-secondary hover:underline font-semibold">Contact us</a> and let's discuss!
      </p>
    </div>
  </div>
</section>
