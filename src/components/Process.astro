---
---
<section class="section-padding bg-primary">
  <div class="container-custom">
    <div class="text-center max-w-4xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4">Our Seamless 3-Trip Inspection Process</h2>
      <div class="w-20 h-1.5 bg-secondary mx-auto mb-6"></div>
      <p class="text-lg text-blue-100/90 font-medium leading-relaxed">
        Comprehensive peace of mind through a structured inspection cycle, ensuring every detail is covered.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
      <!-- Step 1 -->
      <div class="flex flex-col items-center p-8 rounded-2xl bg-white shadow-xl border border-gray-100 transition-transform hover:-translate-y-1 duration-300">
        <div class="relative w-24 h-24 flex items-center justify-center bg-white rounded-full mb-6 shadow-md border-4 border-secondary">
          <span class="text-primary text-4xl font-black">1</span>
        </div>
        <h3 class="text-xl font-bold text-primary mb-3">Initial Inspection</h3>
        <p class="text-gray-600 leading-relaxed">Meticulous identification of all potential defects using specialized equipment.</p>
      </div>

      <!-- Step 2 -->
      <div class="flex flex-col items-center p-8 rounded-2xl bg-white shadow-xl border border-gray-100 transition-transform hover:-translate-y-1 duration-300">
        <div class="relative w-24 h-24 flex items-center justify-center bg-white rounded-full mb-6 shadow-md border-4 border-secondary">
          <span class="text-primary text-4xl font-black">2</span>
        </div>
        <h3 class="text-xl font-bold text-primary mb-3">Joint Inspection</h3>
        <p class="text-gray-600 leading-relaxed">Meeting with BSC/MA to walk through and confirm all findings, ensuring transparency.</p>
      </div>

      <!-- Step 3 -->
      <div class="flex flex-col items-center p-8 rounded-2xl bg-white shadow-xl border border-gray-100 transition-transform hover:-translate-y-1 duration-300">
        <div class="relative w-24 h-24 flex items-center justify-center bg-white rounded-full mb-6 shadow-md border-4 border-secondary">
          <span class="text-primary text-4xl font-black">3</span>
        </div>
        <h3 class="text-xl font-bold text-primary mb-3">Final Rectification</h3>
        <p class="text-gray-600 leading-relaxed">Verification that all identified issues have been effectively resolved before you move in.</p>
      </div>
    </div>
  </div>
</section>
