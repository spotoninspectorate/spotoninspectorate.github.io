---
const services = [
  {
    title: "New Home Defects Inspection",
    description: "Check for defects before proceeding with renovation works so that the whole renovation process can go smoothly.",
    icon: "📋"
  },
  {
    title: "Post Renovation Defects Inspection",
    description: "Ensure that your ID delivers quality workmanship and identify any defects to be rectified.",
    icon: "🛠️"
  },
  {
    title: "Renovation Consultation",
    description: "Get answers to your burning questions during your renovation and help ensure your dream home becomes a reality.",
    icon: "🤝"
  },
  {
    title: "HDB WiFi & Networking",
    description: "Overcome dead zones and thick concrete walls with our professional HDB networking & WiFi mesh consultation.",
    icon: "📶"
  }
];
---
<section id="services" class="section-padding bg-light-bg">
  <div class="container-custom">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-black text-primary mb-4">Our Professional Services</h2>
      <div class="w-20 h-1.5 bg-secondary mx-auto mb-6"></div>
      <p class="text-lg text-gray-600 font-medium leading-relaxed">
        Comprehensive defect inspection and consultation services tailored for Singaporean homeowners.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
      {services.map(service => (
        <div class="bg-white p-8 md:p-10 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
          <div class="text-4xl mb-6 bg-light-bg w-16 h-16 flex items-center justify-center rounded-xl group-hover:bg-secondary/10 transition-colors">
            {service.icon}
          </div>
          <h3 class="text-xl md:text-2xl font-bold text-primary mb-4 group-hover:text-secondary transition-colors">
            {service.title}
          </h3>
          <p class="text-gray-600 leading-relaxed">
            {service.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
