---
<section class="relative min-h-[70vh] flex items-center pt-20 overflow-hidden">
  <!-- Background Image with Gradient Overlay -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-b from-primary/80 to-primary/10 z-10"></div>
    <img 
      src="/img/header-bg.jpg" 
      alt="Modern HDB Interior" 
      class="w-full h-full object-cover object-center"
    />
  </div>

  <div class="container-custom relative z-20 text-white py-20">
    <div class="max-w-3xl">
      <span class="inline-block bg-secondary text-white px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-[0.2em] mb-6 animate-fade-in">
        Just collected your keys?
      </span>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-black leading-[1.1] mb-8 drop-shadow-sm">
        Don't let hidden defects ruin your <span class="text-secondary">renovation plans.</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-100 mb-10 max-w-2xl leading-relaxed font-medium">
        Secure your investment with meticulous HDB defect inspection services you can trust. We catch what others miss before your renovation starts.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="https://wa.me/6580812300?text=Hello%2C%20I%27m%20interested%20to%20find%20out%20more%21" class="btn-gold text-center text-sm md:text-base px-10">
          <span class="flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.438 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 2.042-.535zm11.233-6.182c-.3-.149-1.774-.875-2.048-.976-.276-.1-.476-.149-.676.149-.2.299-.775.976-.95 1.171-.175.194-.35.219-.65.07-.3-.149-1.265-.466-2.41-1.581-.892-.796-1.492-1.779-1.667-2.079-.175-.299-.019-.461.13-.61.135-.133.299-.349.449-.524.15-.175.2-.299.299-.499.1-.2.05-.374-.025-.524-.05-.15-.676-1.626-.925-2.221-.244-.582-.493-.503-.676-.503-.175-.004-.375-.004-.574-.004-.2 0-.525.075-.799.374-.274.299-1.049 1.024-1.049 2.495 0 1.471 1.074 2.893 1.223 3.093.15.2 2.114 3.217 5.122 4.517.715.309 1.273.494 1.708.633.717.228 1.369.196 1.885.119.574-.085 1.774-.724 2.023-1.422.25-.699.25-1.297.175-1.422-.075-.125-.275-.199-.575-.349z"/>
            </svg>
            WhatsApp us now!
          </span>
        </a>
        <a href="#services" class="bg-white/10 backdrop-blur-md text-white border border-white/20 px-10 py-4 rounded font-bold uppercase tracking-wider transition-all duration-300 hover:bg-white/20 text-center text-sm md:text-base">
          View Services
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
